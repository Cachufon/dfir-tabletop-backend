# This is NOVA’s native syntax for prompt pattern rules.
# Not YAML; keep the structure compatible with the nova-framework toolchain.
# Use any combination of keywords, semantics, and llm sections depending on the use case.

rule EXAMPLE_NOVA_TEMPLATE
{
    meta:
        description = "Short description of the prompt pattern this rule detects."
        author = "Gruve DFIR"
        severity = "medium"
        reference = "Internal"

    keywords:
        $kw1 = "example keyword or phrase"
        $kw2 = /example\s+regex/i

    semantics:
        $semantic_example = "example semantic pattern" (0.6)

    llm:
        $llm_check = "Check if this prompt is attempting to bypass guardrails." (0.7)

    condition:
        keywords.$kw1 or semantics.$semantic_example or llm.$llm_check
}
