{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gruve.ai/schemas/ttx_inject_bank.schema.json",
  "title": "TTX Inject Bank",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "injects"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "injects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "tags", "inject"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "tags": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "categories",
              "package_profiles",
              "audiences",
              "csf_functions",
              "mitre_attack",
              "complexity",
              "redline_topics"
            ],
            "properties": {
              "categories": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "package_profiles": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "audiences": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "csf_functions": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "mitre_attack": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "complexity": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              },
              "redline_topics": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          },
          "inject": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "delivery_method",
              "audience",
              "participant_prompt",
              "expected_discussion",
              "expected_decisions",
              "evaluation_criteria",
              "facilitator_notes",
              "evidence_refs"
            ],
            "properties": {
              "delivery_method": { "type": "string", "minLength": 1 },
              "audience": { "type": "string", "minLength": 1 },
              "participant_prompt": { "type": "string", "minLength": 1 },
              "expected_discussion": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "expected_decisions": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "evaluation_criteria": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "facilitator_notes": { "type": "string", "minLength": 1 },
              "evidence_refs": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^(REF_[A-Z0-9_]+|ATTACK:T[0-9]{4}(\\.[0-9]{3})?)$"
                }
              }
            }
          }
        }
      }
    }
  }
}
